{
  "id": "test-university",
  "realm": "test-university",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "bruteForceProtected": false,
  "displayName": "Test University IdP (Dev)",
  "clients": [
    {
      "clientId": "http://localhost:8081/realms/memo",
      "name": "Memo Application (SP)",
      "enabled": true,
      "protocol": "saml",
      "publicClient": false,
      "frontchannelLogout": true,
      "attributes": {
        "saml.authnstatement": "true",
        "saml.server.signature": "true",
        "saml.assertion.signature": "true",
        "saml_force_name_id_format": "true",
        "saml.force.post.binding": "true",
        "saml.client.signature": "false",
        "saml_name_id_format": "persistent",
        "saml.signing.certificate": ""
      },
      "redirectUris": [
        "http://localhost:8081/realms/memo/broker/test-university/endpoint*"
      ],
      "adminUrl": "http://localhost:8081/realms/memo/broker/test-university/endpoint",
      "baseUrl": "http://localhost:3000",
      "protocolMappers": [
        {
          "name": "username",
          "protocol": "saml",
          "protocolMapper": "saml-user-property-mapper",
          "consentRequired": false,
          "config": {
            "attribute.nameformat": "Basic",
            "user.attribute": "username",
            "attribute.name": "username"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "student",
      "enabled": true,
      "credentials": [
        {
          "type": "password",
          "value": "student123",
          "temporary": false
        }
      ]
    },
    {
      "username": "demo",
      "enabled": true,
      "credentials": [
        {
          "type": "password",
          "value": "demo",
          "temporary": false
        }
      ]
    },
    {
      "username": "admin",
      "enabled": true,
      "credentials": [
        {
          "type": "password",
          "value": "admin",
          "temporary": false
        }
      ]
    }
  ]
}
